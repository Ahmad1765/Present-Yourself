# ─── Database / Cache ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/present_yourself
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/present_yourself
REDIS_URL=redis://localhost:6379/0

# ─── Object storage (S3-compatible: R2 in prod, MinIO locally) ──
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=present-yourself

# ─── Crypto ─────────────────────────────────────────────────────
# 32-byte base64 (generate: python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())")
MASTER_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_REAL_32_BYTE_KEY_BASE64==

# ─── Auth (Clerk) ───────────────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ─── System default API keys (optional fallbacks; users can BYOK) ─
SYSTEM_OPENAI_KEY=
SYSTEM_ANTHROPIC_KEY=
SYSTEM_GEMINI_KEY=
SYSTEM_TAVILY_KEY=
SYSTEM_UNSPLASH_KEY=
SYSTEM_PEXELS_KEY=
SYSTEM_PIXABAY_KEY=

# ─── Observability ──────────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO

# ─── Limits ─────────────────────────────────────────────────────
RATE_LIMIT_GENERATIONS_PER_DAY=10
MAX_PPTX_UPLOAD_MB=50
MAX_IMAGE_UPLOAD_MB=10

# ─── Public URLs ────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000
